/**
 * @file    sensor.h
 * @brief   环境传感器驱动 - LDR光敏 + NTC热敏
 */

#ifndef __SENSOR_H
#define __SENSOR_H

#include "main.h"

/* ===================== 光照等级 ===================== */
typedef enum {
    LIGHT_DARK   = 0,   /* 暗光 (< 500 lux) */
    LIGHT_NORMAL = 1,   /* 正常光照 */
    LIGHT_BRIGHT = 2    /* 强光 (> 2000 lux) */
} LightLevel_t;

/* ===================== 温度等级 ===================== */
typedef enum {
    TEMP_COLD    = 0,   /* 偏冷 (< 18 C) */
    TEMP_COMFORT = 1,   /* 舒适 (18-30 C) */
    TEMP_HOT     = 2    /* 偏热 (> 30 C) */
} TempLevel_t;

/* ===================== 原始数据 ===================== */
typedef struct {
    uint16_t ldr_adc;       /* 光敏 ADC 原始值 */
    uint16_t ntc_adc;       /* 热敏 ADC 原始值 */
    uint16_t light_raw;     /* 光敏滤波后 */
    uint16_t temp_raw;      /* 热敏滤波后 */
    LightLevel_t light;     /* 光照等级 */
    TempLevel_t  temp;      /* 温度等级 */
    float  temp_celsius;    /* 温度估算值 (摄氏度) */
} SensorData_t;

/* ===================== API ===================== */

/** 初始化 ADC（已在 CubeMX 生成，此处存根） */
void Sensor_Init(void);

/** 读取 ADC 并更新滤波值，每 20ms 调用一次 */
void Sensor_Update(void);

/** 获取传感器数据指针 */
const SensorData_t* Sensor_GetData(void);

/** 获取光照等级 */
LightLevel_t Sensor_GetLightLevel(void);

/** 获取温度等级 */
TempLevel_t Sensor_GetTempLevel(void);

/** 获取温度摄氏度估算值 */
float Sensor_GetTempCelsius(void);

#endif /* __SENSOR_H */
